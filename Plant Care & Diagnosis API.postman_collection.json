        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "",
                  "// Attempts to find the token in standard response structures",
                  "var token = jsonData.token || (jsonData.data && jsonData.data.token);",
                  "",
                  "if(token) {",
                  "    pm.collectionVariables.set(\"token\", token);",
                  "    console.log(\"Token automatically saved to collection variables!\");",
                  "} else {",
                  "    console.log(\"Could not find token in response. Adjust the test script based on your actual response object.\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
