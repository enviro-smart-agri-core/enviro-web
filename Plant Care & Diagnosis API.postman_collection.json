            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "",
                  "// Attempts to find the _id of the created plant",
                  "var id = jsonData._id || (jsonData.data && jsonData.data._id) || (jsonData.plant && jsonData.plant._id);",
                  "",
                  "if(id) {",
                  "    pm.collectionVariables.set(\"plantId\", id);",
                  "    console.log(\"Plant ID saved for subsequent requests: \" + id);",
