    {
      "name": "3. Diagnosis",
      "item": [
        {
          "name": "Request Upload URL",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate a random string and hash it to bypass the unique sha256 constraint during testing",
                  "var randomString = Math.random().toString(36).substring(7);",
                  "var dynamicHash = CryptoJS.SHA256(randomString).toString();",
                  "",
                  "pm.variables.set(\"dynamicSha256\", dynamicHash);",
                  "console.log(\"Generated random SHA for this request: \" + dynamicHash);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
